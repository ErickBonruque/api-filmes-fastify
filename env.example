# Porta em que o servidor Fastify irá rodar (opcional, padrão: 3000)
PORT=3000

# URL base da API do TMDB
TMDB_BASE_URL=https://api.themoviedb.org/3

# Idioma das respostas (opcional). Ex.: pt-BR, en-US
TMDB_LANGUAGE=pt-BR

# ----------------------------------------------------------------------
# Autenticação no TMDB — use UMA das opções abaixo.
# Este projeto usa o Read Access Token (Bearer) por padrão.
# ----------------------------------------------------------------------

# Opção 1 (recomendada): API Read Access Token
# Enviado no header -> Authorization: Bearer <token>
TMDB_READ_ACCESS_TOKEN=seu_read_access_token_aqui

# Opção 2 (alternativa): API Key v3
# Enviada como query parameter -> ?api_key=<chave>
TMDB_API_KEY=sua_api_key_aqui
